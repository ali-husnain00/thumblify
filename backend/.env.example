# =============================================================================
# Thumblify backend — copy to .env and fill in real values
# =============================================================================

# Google AI Studio API key (Gemini prompt engineering only)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key

# JWT signing secret (use a long random string in production)
JWT_SECRET_KEY=your_jwt_secret_key

# MySQL (keys must match config/db.py)
HOST=localhost
USER=root
PASSWORD=your_mysql_password
DB_NAME=Thumblify
DB_PORT=3306

# -----------------------------------------------------------------------------
# Aiven / cloud MySQL (production)
# -----------------------------------------------------------------------------
# Set HOST, USER, PASSWORD, DB_NAME, DB_PORT from your Aiven dashboard.
# Place the Aiven CA certificate at backend/config/ca.pem (SSL is enabled in db.py).

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI (image generation)
# -----------------------------------------------------------------------------
# 1. Create a service account with Vertex AI User (or equivalent) role.
# 2. Download JSON key and save as backend/key.json (never commit).
# 3. Local: app.py uses GOOGLE_APPLICATION_CREDENTIALS=key.json
# 4. Production: mount secret e.g. /etc/secrets/key.json and update app.py
# 5. Update project id and region in app.py vertexai.init() if needed
